{
  "name": "dev-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local CLI coding agent scaffold for a Claude Code style workflow.",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "npm run build && node dist/main.js",
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "diff": "^7.0.0",
    "dotenv": "^16.4.5",
    "fast-glob": "^3.3.3",
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "openai": "^4.104.0",
    "react": "^18.3.1",
    "strip-ansi": "^7.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.12",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
